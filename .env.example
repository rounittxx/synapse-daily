# ── Claude API ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail SMTP ──────────────────────────────────────────────────
# Use an App Password, NOT your regular password.
# Generate: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Supabase (subscriber storage) ───────────────────────────────
# Create a free project at https://supabase.com
# Get these from: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# ── Fallback recipients (if Supabase isn't configured) ──────────
RECIPIENT_EMAILS=you@example.com

# ── Newsletter config ────────────────────────────────────────────
NEWSLETTER_NAME=Synapse Daily
MAX_ARTICLES=15
TOP_STORIES=5
DRY_RUN=false
